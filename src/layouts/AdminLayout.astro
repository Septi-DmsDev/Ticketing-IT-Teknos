---
import '../styles/global.css';

interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav = '' } = Astro.props;

// Get user from locals (set by middleware)
const user = Astro.locals.user;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | IT Admin Dashboard</title>
  </head>
  <body class="bg-bg font-sans">
    <div class="flex min-h-screen overflow-hidden">

      <div id="admin-sidebar-backdrop" class="fixed inset-0 z-30 bg-slate-950/45 backdrop-blur-[1px] opacity-0 pointer-events-none transition-opacity duration-200 lg:hidden"></div>

      <!-- Sidebar -->
      <aside id="admin-sidebar" class="fixed inset-y-0 left-0 z-40 w-72 max-w-[85vw] -translate-x-full bg-primary flex flex-col flex-shrink-0 transition-transform duration-200 lg:static lg:z-auto lg:w-64 lg:max-w-none lg:translate-x-0">
        <!-- Logo -->
        <div class="px-6 py-6 border-b border-white/10">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-white/15 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
            </div>
            <div>
              <p class="text-white font-700 text-sm leading-tight">IT Admin</p>
              <p class="text-white/40 text-xs">Dashboard</p>
            </div>
          </div>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
          <a href="/admin" class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-500 transition-colors ${activeNav === 'dashboard' ? 'bg-white/15 text-white' : 'text-white/60 hover:text-white hover:bg-white/8'}`}>
            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            Beranda
          </a>

          <div class="pt-3 pb-1 px-3">
            <p class="text-white/30 text-xs font-600 uppercase tracking-widest">Tiket</p>
          </div>

          <a href="/admin/support" class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-500 transition-colors ${activeNav === 'support' ? 'bg-white/15 text-white' : 'text-white/60 hover:text-white hover:bg-white/8'}`}>
            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            Tiket Support
            <span id="support-badge" class="ml-auto bg-red-500 text-white text-xs font-700 px-1.5 py-0.5 rounded-full hidden"></span>
          </a>

          <a href="/admin/pengajuan" class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-500 transition-colors ${activeNav === 'pengajuan' ? 'bg-white/15 text-white' : 'text-white/60 hover:text-white hover:bg-white/8'}`}>
            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Pengajuan Sistem
          </a>

          <div class="pt-3 pb-1 px-3">
            <p class="text-white/30 text-xs font-600 uppercase tracking-widest">Pengaturan</p>
          </div>

          <a href="/admin/kategori" class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-500 transition-colors ${activeNav === 'kategori' ? 'bg-white/15 text-white' : 'text-white/60 hover:text-white hover:bg-white/8'}`}>
            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
            Kategori Support
          </a>

          {Astro.locals.profile?.role === 'super_admin' && (
            <a href="/admin/tim" class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-500 transition-colors ${activeNav === 'tim' ? 'bg-white/15 text-white' : 'text-white/60 hover:text-white hover:bg-white/8'}`}>
              <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
              Tim IT
            </a>
          )}
        </nav>

        <!-- User info & Logout -->
        <div class="px-3 py-4 border-t border-white/10">
          <div class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-white/8 mb-2">
            <div class="w-7 h-7 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div class="overflow-hidden flex-1">
              <p class="text-white text-xs font-600 truncate">{user?.email || 'Admin'}</p>
              <p class="text-white/40 text-xs">{Astro.locals.profile?.role === 'super_admin' ? 'Super Admin' : 'IT Staff'}</p>
            </div>
          </div>
          <a href="/admin/logout" class="flex items-center gap-2 px-3 py-2 text-white/50 hover:text-white text-xs font-500 transition-colors rounded-lg hover:bg-white/8">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            Keluar
          </a>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col overflow-hidden lg:min-w-0">
        <!-- Top Bar -->
        <header class="bg-white border-b border-border px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between gap-3 flex-shrink-0">
          <div class="flex items-center gap-3 min-w-0">
            <button
              id="admin-sidebar-toggle"
              type="button"
              class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-border bg-bg text-text-dark lg:hidden"
              aria-controls="admin-sidebar"
              aria-expanded="false"
              aria-label="Buka navigasi admin"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
            <h1 class="font-700 text-text-dark text-base sm:text-lg truncate">{title}</h1>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <!-- Notification Bell Button -->
            <button
              id="notif-btn"
              type="button"
              title="Notifikasi tiket baru"
              class="relative inline-flex h-10 w-10 items-center justify-center rounded-xl border border-border bg-bg text-text-dark hover:bg-border transition-colors"
              aria-label="Toggle notifikasi"
            >
              <!-- Bell icon -->
              <svg id="notif-icon-bell" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
              </svg>
              <!-- Active dot -->
              <span id="notif-active-dot" class="hidden absolute top-1.5 right-1.5 w-2 h-2 bg-green-500 rounded-full ring-2 ring-white"></span>
            </button>
            <a href="/" target="_blank" class="text-secondary text-sm hover:text-primary transition-colors flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              <span class="hidden sm:inline">Lihat halaman publik</span>
              <span class="sm:hidden">Publik</span>
            </a>
          </div>
        </header>

        <!-- Page Content -->
        <main class="flex-1 overflow-y-auto px-4 py-5 sm:px-6 sm:py-6 lg:px-8 lg:py-8">
          <slot />
        </main>
      </div>

    </div>

    <script>
      const sidebar = document.getElementById('admin-sidebar');
      const toggle = document.getElementById('admin-sidebar-toggle');
      const backdrop = document.getElementById('admin-sidebar-backdrop');

      function setSidebar(open: boolean) {
        if (!sidebar || !toggle || !backdrop) return;
        sidebar.classList.toggle('-translate-x-full', !open);
        backdrop.classList.toggle('opacity-0', !open);
        backdrop.classList.toggle('pointer-events-none', !open);
        toggle.setAttribute('aria-expanded', String(open));
        document.body.classList.toggle('overflow-hidden', open);
      }

      toggle?.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        setSidebar(!expanded);
      });

      backdrop?.addEventListener('click', () => setSidebar(false));

      window.addEventListener('resize', () => {
        if (window.innerWidth >= 1024) setSidebar(false);
      });
    </script>

    <!-- Notification + Realtime Script -->
    <script>
      import {
        isNotificationEnabled,
        isNotificationsSupported,
        getNotificationState,
        requestNotificationPermission,
        disableNotifications,
        startRealtimeNotifications,
        refreshSupportBadge,
      } from '../lib/realtime-notifications';

      // ── Service Worker Registration ──────────────────────────
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch((err) => {
          console.warn('[SW] Registration failed:', err);
        });
      }

      // ── Badge count on load ──────────────────────────────────
      refreshSupportBadge();

      // ── Notification Button State ────────────────────────────
      const notifBtn = document.getElementById('notif-btn');
      const activeDot = document.getElementById('notif-active-dot');

      function updateNotifUI() {
        if (!notifBtn || !activeDot) return;
        const enabled = isNotificationEnabled();
        const state = getNotificationState();

        if (enabled) {
          notifBtn.classList.add('border-green-300', 'bg-green-50', 'text-green-700');
          notifBtn.classList.remove('border-border', 'bg-bg', 'text-text-dark');
          notifBtn.title = 'Notifikasi aktif — klik untuk matikan';
          activeDot.classList.remove('hidden');
        } else {
          notifBtn.classList.remove('border-green-300', 'bg-green-50', 'text-green-700');
          notifBtn.classList.add('border-border', 'bg-bg', 'text-text-dark');
          notifBtn.title = state === 'denied'
            ? 'Notifikasi diblokir browser — ubah izin di pengaturan browser'
            : 'Klik untuk aktifkan notifikasi tiket baru';
          activeDot.classList.add('hidden');
        }
      }

      notifBtn?.addEventListener('click', async () => {
        if (!isNotificationsSupported()) {
          alert('Browser Anda tidak mendukung notifikasi.');
          return;
        }

        if (isNotificationEnabled()) {
          // Turn off
          disableNotifications();
          updateNotifUI();
          return;
        }

        const state = getNotificationState();
        if (state === 'denied') {
          alert('Notifikasi diblokir. Buka pengaturan browser → Site Settings → Notifications dan izinkan situs ini.');
          return;
        }

        const granted = await requestNotificationPermission();
        if (granted) {
          startRealtimeNotifications();
          // Show test notification
          new Notification('✅ Notifikasi Aktif!', {
            body: 'Anda akan menerima notifikasi saat ada tiket baru masuk.',
            icon: '/favicon.svg',
          });
        }
        updateNotifUI();
      });

      // ── Auto-start if already enabled ────────────────────────
      if (isNotificationEnabled()) {
        startRealtimeNotifications();
      }

      // Initialise UI state
      updateNotifUI();

      // ── Listen for new ticket events (e.g. to flash badge) ───
      window.addEventListener('it:new-ticket', (e: Event) => {
        const { type } = (e as CustomEvent).detail;
        if (type === 'support') refreshSupportBadge();
      });
    </script>
  </body>
</html>
