---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ajukan Sistem Baru" description="Ajukan permintaan pengembangan sistem atau fitur baru ke tim IT.">
  <main class="min-h-screen bg-bg">
    
    <!-- Header -->
    <header class="bg-primary">
      <div class="max-w-3xl mx-auto px-6 py-4 flex items-center gap-4">
        <a href="/" class="text-white/60 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </a>
        <div>
          <p class="text-white font-600 text-sm">Pengajuan Sistem / Fitur Baru</p>
          <p class="text-white/50 text-xs">Modul 1 — IT Ticketing System</p>
        </div>
      </div>
    </header>

    <div class="max-w-3xl mx-auto px-6 py-10">

      <!-- Form Info Banner -->
      <div class="bg-white border border-border rounded-2xl p-5 mb-8 flex items-start gap-4">
        <div class="w-10 h-10 bg-primary/8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="font-600 text-text-dark text-sm mb-1">Formulir ini untuk permintaan pengembangan jangka menengah/panjang.</p>
          <p class="text-secondary text-sm">Setelah disubmit, tim IT akan menganalisis dan menghubungi Anda lebih lanjut. Simpan kode tiket yang Anda dapatkan untuk melacak progress.</p>
        </div>
      </div>

      <!-- Form -->
      <form id="pengajuan-form" class="space-y-8">

        <!-- Section: Identitas -->
        <section class="bg-white border border-border rounded-2xl overflow-hidden">
          <div class="px-7 py-5 border-b border-border">
            <h2 class="font-700 text-text-dark text-base">Identitas Pemohon</h2>
            <p class="text-secondary text-sm mt-0.5">Data diri tidak digunakan untuk login, hanya untuk keperluan identifikasi tiket.</p>
          </div>
          <div class="px-7 py-6 grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="md:col-span-2">
              <label for="req-name" class="block text-sm font-600 text-text-dark mb-2">Nama Lengkap <span class="text-red-500">*</span></label>
              <input id="req-name" name="name" type="text" required placeholder="Masukkan nama lengkap Anda" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light" />
            </div>
            <div>
              <label for="req-position" class="block text-sm font-600 text-text-dark mb-2">Jabatan / Posisi <span class="text-red-500">*</span></label>
              <input id="req-position" name="position" type="text" required placeholder="Contoh: Staff Keuangan" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light" />
            </div>
            <div>
              <label for="req-division" class="block text-sm font-600 text-text-dark mb-2">Divisi / Departemen <span class="text-red-500">*</span></label>
              <input id="req-division" name="division" type="text" required placeholder="Contoh: Keuangan & Akuntansi" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light" />
            </div>
            <div class="md:col-span-2">
              <label for="req-contact" class="block text-sm font-600 text-text-dark mb-2">Kontak yang Bisa Dihubungi <span class="text-secondary font-400">(Opsional)</span></label>
              <input id="req-contact" name="contact" type="text" placeholder="Contoh: ext. 1234 atau email internal" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light" />
            </div>
          </div>
        </section>

        <!-- Section: Detail Pengajuan -->
        <section class="bg-white border border-border rounded-2xl overflow-hidden">
          <div class="px-7 py-5 border-b border-border">
            <h2 class="font-700 text-text-dark text-base">Detail Pengajuan</h2>
            <p class="text-secondary text-sm mt-0.5">Jelaskan kebutuhan Anda sedetail mungkin agar tim IT dapat menilai dengan tepat.</p>
          </div>
          <div class="px-7 py-6 space-y-5">
            
            <div>
              <label for="req-title" class="block text-sm font-600 text-text-dark mb-2">Judul Pengajuan <span class="text-red-500">*</span></label>
              <input id="req-title" name="title" type="text" required placeholder="Contoh: Sistem Absensi Berbasis Wajah" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light" />
            </div>

            <div>
              <label for="req-background" class="block text-sm font-600 text-text-dark mb-2">Latar Belakang / Masalah <span class="text-red-500">*</span></label>
              <p class="text-secondary text-xs mb-2">Apa masalah yang saat ini terjadi? Mengapa sistem/fitur ini dibutuhkan?</p>
              <textarea id="req-background" name="background" required rows="4" placeholder="Jelaskan kondisi saat ini dan masalah yang ingin diselesaikan..." class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light resize-none"></textarea>
            </div>

            <div>
              <label for="req-description" class="block text-sm font-600 text-text-dark mb-2">Deskripsi Kebutuhan <span class="text-red-500">*</span></label>
              <p class="text-secondary text-xs mb-2">Ekspektasi Anda: sistem/fitur ini seharusnya bisa melakukan apa?</p>
              <textarea id="req-description" name="description" required rows="4" placeholder="Jelaskan fitur atau kemampuan yang diharapkan dari sistem baru ini..." class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light resize-none"></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label for="req-priority" class="block text-sm font-600 text-text-dark mb-2">Tingkat Prioritas <span class="text-red-500">*</span></label>
                <p class="text-secondary text-xs mb-2">Menurut pandangan Anda. Tim IT dapat menyesuaikan berdasarkan resource.</p>
                <select id="req-priority" name="priority" required class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all bg-white appearance-none cursor-pointer">
                  <option value="" disabled selected>Pilih prioritas...</option>
                  <option value="low">Rendah — Tidak mendesak</option>
                  <option value="medium">Sedang — Cukup penting</option>
                  <option value="high">Tinggi — Sangat dibutuhkan segera</option>
                </select>
              </div>
              <div>
                <label for="req-target-date" class="block text-sm font-600 text-text-dark mb-2">Target Selesai <span class="text-secondary font-400">(Opsional)</span></label>
                <p class="text-secondary text-xs mb-2">Kapan fitur ini idealnya sudah tersedia?</p>
                <input id="req-target-date" name="target_date" type="date" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
              </div>
            </div>

            <div>
              <label for="req-attachment" class="block text-sm font-600 text-text-dark mb-2">Lampiran / Draf Konsep <span class="text-red-500">* (Wajib)</span></label>
              <p class="text-secondary text-xs mb-2">Upload mockup, referensi desain, atau dokumen draf konsep awal. Format: JPG, PNG, atau PDF. Maks 5MB.</p>
              <label for="req-attachment" class="flex flex-col items-center justify-center gap-2 w-full border-2 border-dashed border-border rounded-xl p-6 cursor-pointer hover:border-primary hover:bg-primary/3 transition-all group">
                <svg class="w-8 h-8 text-secondary-light group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <div class="text-center">
                  <p id="attachment-label" class="text-sm text-secondary">Klik untuk memilih file draf/konsep atau drag & drop</p>
                  <p class="text-xs text-secondary-light">Wajib upload draf pendukung (JPG, PNG, PDF — Maks. 5MB)</p>
                </div>
                <input id="req-attachment" name="attachment" type="file" class="hidden" accept=".jpg,.jpeg,.png,.pdf" />
              </label>
            </div>

          </div>
        </section>

        <!-- Submit Button -->
        <div class="flex items-center justify-between">
          <a href="/" class="text-secondary text-sm hover:text-text-dark transition-colors">← Kembali ke beranda</a>
          <button type="submit" id="submit-btn" class="bg-primary text-white font-600 px-8 py-3.5 rounded-xl hover:bg-primary-hover transition-colors flex items-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
            Kirim Pengajuan
          </button>
        </div>

      </form>
    </div>

    <!-- Success Modal -->
    <div id="success-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-primary/60 backdrop-blur-sm">
      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8 text-center">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-5">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h2 class="text-xl font-700 text-text-dark mb-2">Pengajuan Berhasil Dikirim!</h2>
        <p class="text-secondary text-sm mb-6">Tim IT akan segera meninjau permintaan Anda. Simpan kode tiket berikut untuk melacak progress:</p>
        <div class="bg-bg border border-border rounded-xl px-6 py-4 mb-6">
          <p class="text-secondary text-xs mb-1">Kode Tiket Anda</p>
          <p id="success-ticket-code" class="text-2xl font-700 font-mono text-primary tracking-wider"></p>
        </div>
        <button onclick="copyCode()" class="w-full bg-primary text-white font-600 py-3 rounded-xl hover:bg-primary-hover transition-colors mb-3">
          Salin Kode Tiket
        </button>
        <a href="/" class="block text-secondary text-sm hover:text-text-dark transition-colors">Kembali ke Beranda</a>
      </div>
    </div>

  </main>
</Layout>

<script>
  import { submitFeatureRequest, uploadAttachment } from '../lib/ticket';

  function updateFileName(input: HTMLInputElement, labelId: string) {
    const label = document.getElementById(labelId);
    if (label && input.files && input.files[0]) {
      label.textContent = input.files[0].name;
    }
  }

  function copyCode() {
    const code = document.getElementById('success-ticket-code')?.textContent;
    if (code) navigator.clipboard.writeText(code);
  }

  function showError(msg: string) {
    const existing = document.getElementById('form-error');
    if (existing) existing.remove();
    const div = document.createElement('div');
    div.id = 'form-error';
    div.className = 'bg-red-50 border border-red-200 rounded-xl p-4 text-sm text-red-800 mb-4';
    div.textContent = '⚠️ ' + msg;
    const form = document.getElementById('pengajuan-form');
    form?.insertBefore(div, form.firstChild);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Attach event listener for file upload
    const attachmentInput = document.getElementById('req-attachment') as HTMLInputElement;
    if (attachmentInput) {
      attachmentInput.addEventListener('change', function() {
        updateFileName(this, 'attachment-label');
      });
    }
  });

  (window as any).updateFileName = updateFileName;
  (window as any).copyCode = copyCode;

  document.getElementById('pengajuan-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.textContent = 'Mengupload Lampiran...';
    btn.textContent = 'Memproses...';

    const formData = new FormData(form);
    
    try {
      const attachmentFile = formData.get('attachment') as File;
      let attachment_url: string | undefined = undefined;

      if (!attachmentFile || attachmentFile.size === 0) {
        showError('Wajib mengupload draf konsep atau lampiran.');
        btn.disabled = false;
        btn.innerHTML = originalHTML;
        return;
      }

      if (attachmentFile && attachmentFile.size > 0) {
        const url = await uploadAttachment(attachmentFile);
        if (url) attachment_url = url;
        else {
          showError('Gagal mengupload lampiran. Pastikan file valid.');
          btn.disabled = false;
          btn.innerHTML = originalHTML;
          return;
        }
      }

      btn.textContent = 'Mengirim Pengajuan...';

      const result = await submitFeatureRequest({
        requester_name: formData.get('name') as string,
        requester_position: formData.get('position') as string,
        requester_division: formData.get('division') as string,
        title: formData.get('title') as string,
        background: formData.get('background') as string,
        description: formData.get('description') as string,
        user_priority: formData.get('priority') as 'low' | 'medium' | 'high',
        target_date: formData.get('target_date') as string || undefined,
        attachment_url: attachment_url
      });

      if (result.success && result.ticket_code) {
        // Save to localStorage
        try {
          const saved = JSON.parse(localStorage.getItem('saved_tickets') || '[]');
          saved.unshift({ 
            code: result.ticket_code, 
            title: 'Pengajuan: ' + formData.get('title'), 
            date: new Date().toISOString() 
          });
          localStorage.setItem('saved_tickets', JSON.stringify(saved.slice(0, 10)));
        } catch (e) {
          console.error('Failed to save ticket to localStorage', e);
        }

        const modal = document.getElementById('success-modal');
        const codeEl = document.getElementById('success-ticket-code');
        if (codeEl) codeEl.textContent = result.ticket_code;
        if (modal) modal.classList.remove('hidden');
      } else {
        showError(result.error || 'Gagal mengirim pengajuan. Silakan coba lagi.');
        btn.disabled = false;
        btn.innerHTML = originalHTML;
      }
    } catch (err: any) {
      console.error(err);
      showError('Terjadi kesalahan tidak terduga saat memproses laporan: ' + err.message);
      btn.disabled = false;
      btn.innerHTML = originalHTML;
    }
  });
</script>
