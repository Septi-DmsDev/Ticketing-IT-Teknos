---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lapor Kendala (Support)" description="Laporkan kendala teknis atau masalah operasional ke tim IT untuk ditangani segera.">
  <main class="min-h-screen bg-bg">
    
    <!-- Header -->
    <header class="bg-primary">
      <div class="max-w-3xl mx-auto px-6 py-4 flex items-center gap-4">
        <a href="/" class="text-white/60 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </a>
        <div>
          <p class="text-white font-600 text-sm">Lapor Kendala (Support)</p>
          <p class="text-white/50 text-xs">Modul 2 — IT Ticketing System</p>
        </div>
      </div>
    </header>

    <div class="max-w-3xl mx-auto px-6 py-10">

      <!-- SLA Banner -->
      <div class="bg-white border border-border rounded-2xl p-5 mb-8 flex items-start gap-4">
        <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="font-600 text-text-dark text-sm mb-1">SLA Respons: Maks. 2 Jam</p>
          <p class="text-secondary text-sm">Setelah tiket masuk, tim IT berkomitmen untuk memberikan respons pertama dalam waktu 2 jam kerja. Notifikasi update akan dikirim ke WhatsApp Anda (jika diisi).</p>
        </div>
      </div>

      <!-- Form -->
      <form id="support-form" class="space-y-8">

        <!-- Section: Identitas Pelapor -->
        <section class="bg-white border border-border rounded-2xl overflow-hidden">
          <div class="px-7 py-5 border-b border-border">
            <h2 class="font-700 text-text-dark text-base">Identitas Pelapor</h2>
            <p class="text-secondary text-sm mt-0.5">Data diri untuk keperluan identifikasi dan tindak lanjut tiket.</p>
          </div>
          <div class="px-7 py-6 grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="md:col-span-2">
              <label for="sup-name" class="block text-sm font-600 text-text-dark mb-2">Nama Lengkap <span class="text-red-500">*</span></label>
              <input id="sup-name" name="name" type="text" required placeholder="Masukkan nama lengkap Anda" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light" />
            </div>
            <div>
              <label for="sup-position" class="block text-sm font-600 text-text-dark mb-2">Jabatan / Posisi <span class="text-red-500">*</span></label>
              <input id="sup-position" name="position" type="text" required placeholder="Contoh: Staff Operasional" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light" />
            </div>
            <div>
              <label for="sup-division" class="block text-sm font-600 text-text-dark mb-2">Divisi / Departemen <span class="text-red-500">*</span></label>
              <input id="sup-division" name="division" type="text" required placeholder="Contoh: Operasional" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light" />
            </div>
            <div class="md:col-span-2">
              <label for="sup-whatsapp" class="block text-sm font-600 text-text-dark mb-2">Nomor WhatsApp <span class="text-red-500">*</span></label>
              <input id="sup-whatsapp" name="whatsapp" type="tel" required placeholder="Contoh: 08123456789 (untuk notifikasi status tiket)" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light" />
            </div>
          </div>
        </section>

        <!-- Section: Detail Masalah -->
        <section class="bg-white border border-border rounded-2xl overflow-hidden">
          <div class="px-7 py-5 border-b border-border">
            <h2 class="font-700 text-text-dark text-base">Detail Masalah</h2>
            <p class="text-secondary text-sm mt-0.5">Semakin detail Anda menjelaskan, semakin cepat tim IT dapat mendiagnosis dan menyelesaikan masalah.</p>
          </div>
          <div class="px-7 py-6 space-y-5">

            <div>
              <label for="sup-category" class="block text-sm font-600 text-text-dark mb-2">Kategori Masalah <span class="text-red-500">*</span></label>
              <select id="sup-category" name="category" required class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all bg-white appearance-none cursor-pointer">
                <option value="" disabled selected>Pilih kategori masalah...</option>
                <option value="hardware">Hardware (PC, Laptop, Printer, dsb.)</option>
                <option value="software">Software / Aplikasi</option>
                <option value="network">Jaringan / Internet / WiFi</option>
                <option value="access">Akun & Akses (Password, Izin, dsb.)</option>
                <option value="other">Lainnya</option>
              </select>
            </div>

            <div>
              <label for="sup-description" class="block text-sm font-600 text-text-dark mb-2">Deskripsi Detail <span class="text-red-500">*</span></label>
              <p class="text-secondary text-xs mb-2">Jelaskan masalah yang terjadi: sejak kapan, di mana, dan apa yang sudah Anda coba?</p>
              <textarea id="sup-description" name="description" required rows="5" placeholder="Contoh: Sejak tadi pagi printer di ruang A101 tidak bisa mencetak. Sudah dicoba restart tapi tetap error. Muncul pesan 'Paper Jam' padahal kertas tidak ada yang nyangkut..." class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light resize-none"></textarea>
            </div>

            <div>
              <label for="sup-location" class="block text-sm font-600 text-text-dark mb-2">Lokasi / Ruangan <span class="text-secondary font-400">(Opsional, sangat disarankan untuk masalah hardware/jaringan)</span></label>
              <input id="sup-location" name="location" type="text" placeholder="Contoh: Lantai 2, Ruang Meeting A, Meja no. 12" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light" />
            </div>

            <div>
              <label for="sup-attachment" class="block text-sm font-600 text-text-dark mb-2">Bukti Error / Lampiran <span class="text-red-500">* (Wajib)</span></label>
              <p class="text-secondary text-xs mb-2">Wajib mengupload screenshot error atau foto kondisi di lapangan. Format: JPG, PNG. Maks 5MB.</p>
              <label for="sup-attachment" class="flex flex-col items-center justify-center gap-2 w-full border-2 border-dashed border-border rounded-xl p-6 cursor-pointer hover:border-primary hover:bg-primary/3 transition-all group">
                <svg class="w-8 h-8 text-secondary-light group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <div class="text-center">
                  <p id="sup-attachment-label" class="text-sm text-secondary">Klik untuk memilih gambar atau drag & drop</p>
                  <p class="text-xs text-secondary-light">Wajib upload bukti (JPG, PNG — Maks. 5MB)</p>
                </div>
                <input id="sup-attachment" name="attachment" type="file" required class="hidden" accept=".jpg,.jpeg,.png" onchange="updateFileName(this, 'sup-attachment-label')" />
              </label>
            </div>

          </div>
        </section>

        <!-- Submit Button -->
        <div class="flex items-center justify-between">
          <a href="/" class="text-secondary text-sm hover:text-text-dark transition-colors">← Kembali ke beranda</a>
          <button type="submit" id="support-submit-btn" class="bg-primary text-white font-600 px-8 py-3.5 rounded-xl hover:bg-primary-hover transition-colors flex items-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
            Kirim Laporan
          </button>
        </div>

      </form>
    </div>

    <!-- Success Modal -->
    <div id="success-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-primary/60 backdrop-blur-sm">
      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8 text-center">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-5">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h2 class="text-xl font-700 text-text-dark mb-2">Laporan Berhasil Dikirim!</h2>
        <p class="text-secondary text-sm mb-6">Tim IT akan merespons dalam waktu <strong>maksimal 2 jam</strong>. Simpan kode tiket ini untuk memantau progress:</p>
        <div class="bg-bg border border-border rounded-xl px-6 py-4 mb-6">
          <p class="text-secondary text-xs mb-1">Kode Tiket Anda</p>
          <p id="success-ticket-code" class="text-2xl font-700 font-mono text-primary tracking-wider"></p>
        </div>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 mb-5 text-xs text-amber-800 text-left">
          <strong>Penting:</strong> Catat kode ini. Kode tiket <strong>tidak dapat dipulihkan</strong> jika hilang.
        </div>
        <button onclick="copyCode()" class="w-full bg-primary text-white font-600 py-3 rounded-xl hover:bg-primary-hover transition-colors mb-3">
          Salin Kode Tiket
        </button>
        <a href="/" class="block text-secondary text-sm hover:text-text-dark transition-colors">Kembali ke Beranda</a>
      </div>
    </div>

  </main>
</Layout>

<script>
  import { submitSupportTicket, getActiveCategories } from '../lib/ticket';

  // Load dynamic categories from Supabase
  async function loadCategories() {
    const select = document.getElementById('sup-category') as HTMLSelectElement;
    if (!select) return;
    try {
      const cats = await getActiveCategories();
      if (cats.length > 0) {
        // Clear existing options except placeholder
        while (select.options.length > 1) select.remove(1);
        cats.forEach((cat: { id: string; name: string }) => {
          const option = new Option(cat.name, cat.id);
          select.add(option);
        });
        // Add 'Other' option at the end
        select.add(new Option('Lainnya', 'other'));
      }
    } catch {
      // Fallback to hardcoded options if Supabase unavailable
      console.warn('Could not load categories from Supabase, using fallback.');
    }
  }

  function updateFileName(input: HTMLInputElement, labelId: string) {
    const label = document.getElementById(labelId);
    if (label && input.files && input.files[0]) {
      label.textContent = input.files[0].name;
    }
  }

  function copyCode() {
    const code = document.getElementById('success-ticket-code')?.textContent;
    if (code) navigator.clipboard.writeText(code);
  }

  function showError(msg: string) {
    const existing = document.getElementById('form-error');
    if (existing) existing.remove();
    const div = document.createElement('div');
    div.id = 'form-error';
    div.className = 'bg-red-50 border border-red-200 rounded-xl p-4 text-sm text-red-800 mb-4';
    div.textContent = '⚠️ ' + msg;
    const form = document.getElementById('support-form');
    form?.insertBefore(div, form.firstChild);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  (window as any).updateFileName = updateFileName;
  (window as any).copyCode = copyCode;

  document.addEventListener('DOMContentLoaded', () => {
    loadCategories();
  });

  document.getElementById('support-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = document.getElementById('support-submit-btn') as HTMLButtonElement;
    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.textContent = 'Mengupload Screenshot...';

    const formData = new FormData(form);
    const categorySelect = document.getElementById('sup-category') as HTMLSelectElement;
    const categoryName = categorySelect.options[categorySelect.selectedIndex].text;
    
    // Format WhatsApp Number
    const rawWa = formData.get('whatsapp') as string;
    const waNumber = formatWhatsAppNumber(rawWa);
    
    try {
      const attachmentFile = formData.get('attachment') as File;
      let attachment_url: string | undefined = undefined;

      if (attachmentFile && attachmentFile.size > 0) {
        const url = await uploadAttachment(attachmentFile);
        if (url) attachment_url = url;
        else {
          showError('Gagal mengupload screenshot. Pastikan file valid dan ukuran tidak melebihi 5MB.');
          btn.disabled = false;
          btn.innerHTML = originalHTML;
          return;
        }
      }

      btn.textContent = 'Mengirim Laporan...';

      const result = await submitSupportTicket({
        reporter_name: formData.get('name') as string,
        reporter_position: formData.get('position') as string,
        reporter_division: formData.get('division') as string,
        whatsapp_number: waNumber || undefined,
        category_id: formData.get('category') as string,
        category_name: categoryName,
        description: formData.get('description') as string,
        location: formData.get('location') as string || undefined,
        attachment_url: attachment_url
      });

      if (result.success && result.ticket_code) {
        // Save to localStorage
        try {
          const saved = JSON.parse(localStorage.getItem('saved_tickets') || '[]');
          saved.unshift({ 
            code: result.ticket_code, 
            title: 'Support: ' + (categoryName), 
            date: new Date().toISOString() 
          });
          localStorage.setItem('saved_tickets', JSON.stringify(saved.slice(0, 10)));
        } catch (e) {
          console.error('Failed to save ticket to localStorage', e);
        }

        const modal = document.getElementById('success-modal');
        const codeEl = document.getElementById('success-ticket-code');
        if (codeEl) codeEl.textContent = result.ticket_code;
        if (modal) modal.classList.remove('hidden');
      } else {
        showError(result.error || 'Gagal mengirim laporan. Silakan coba lagi.');
        btn.disabled = false;
        btn.innerHTML = originalHTML;
      }
    } catch (err: any) {
      console.error(err);
      showError('Terjadi kesalahan tidak terduga saat memproses laporan: ' + err.message);
      btn.disabled = false;
      btn.innerHTML = originalHTML;
    }
  });
</script>
