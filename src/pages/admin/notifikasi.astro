---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin as supabase } from '../../lib/supabase';

const HEARTBEAT_STALE_MS = 2 * 60 * 1000; // 2 minutes
const OUTBOX_STATUSES = ['pending', 'sending', 'sent', 'failed', 'dead'] as const;
const RETRYABLE_STATUSES = new Set(['failed', 'dead']);

const statusFilter = Astro.url.searchParams.get('status');
const errorParam = Astro.url.searchParams.get('error');

function redirectTarget(overrides: { error?: string } = {}) {
  const params = new URLSearchParams();
  if (statusFilter) params.set('status', statusFilter);
  if (overrides.error) params.set('error', overrides.error);
  const qs = params.toString();
  return `/admin/notifikasi${qs ? `?${qs}` : ''}`;
}

// Handle POST actions: retry, set_admin_group_jid
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action') as string;

  if (action === 'retry') {
    const id = form.get('id') as string;
    if (id) {
      await supabase
        .from('notification_outbox')
        .update({ status: 'pending', next_attempt_at: new Date().toISOString() })
        .eq('id', id);
    }
    return Astro.redirect(redirectTarget());
  }

  if (action === 'set_admin_group_jid') {
    const rawJid = (form.get('jid') as string | null) ?? '';
    const jid = rawJid.trim();

    if (!jid || !jid.endsWith('@g.us')) {
      return Astro.redirect(redirectTarget({ error: 'invalid_group_jid' }));
    }

    await supabase
      .from('notification_settings')
      .update({ admin_group_jid: jid, updated_at: new Date().toISOString() })
      .eq('id', 'default');

    return Astro.redirect(redirectTarget());
  }

  return Astro.redirect(redirectTarget());
}

// --- Bot heartbeat ---
const { data: heartbeat } = await supabase
  .from('bot_heartbeat')
  .select('*')
  .eq('id', 'whatsapp-bot')
  .maybeSingle();

const lastHeartbeatMs = heartbeat?.last_heartbeat_at ? new Date(heartbeat.last_heartbeat_at).getTime() : null;
const isHeartbeatFresh = lastHeartbeatMs !== null && (Date.now() - lastHeartbeatMs) <= HEARTBEAT_STALE_MS;
const isStaleConnected = heartbeat?.connection_state === 'connected' && !isHeartbeatFresh;

type HealthTier = 'connected' | 'qr_pending' | 'down';
let healthTier: HealthTier = 'down';
if (heartbeat?.connection_state === 'connected' && isHeartbeatFresh) {
  healthTier = 'connected';
} else if (heartbeat?.connection_state === 'qr_pending') {
  healthTier = 'qr_pending';
} else {
  healthTier = 'down';
}

const HEALTH_STYLES: Record<HealthTier, string> = {
  connected: 'bg-green-50 text-green-700 border border-green-200',
  qr_pending: 'bg-yellow-50 text-yellow-700 border border-yellow-200',
  down: 'bg-red-50 text-red-700 border border-red-200',
};
const HEALTH_DOT: Record<HealthTier, string> = {
  connected: 'bg-green-500',
  qr_pending: 'bg-yellow-500',
  down: 'bg-red-500',
};

let healthLabel = 'Tidak Diketahui';
if (healthTier === 'connected') {
  healthLabel = 'Terhubung';
} else if (healthTier === 'qr_pending') {
  healthLabel = 'Menunggu Scan QR';
} else if (isStaleConnected) {
  healthLabel = 'Heartbeat Basi (Proses Bot Kemungkinan Mati/Hang)';
} else if (heartbeat?.connection_state === 'logged_out') {
  healthLabel = 'Logged Out';
} else if (heartbeat?.connection_state === 'disconnected') {
  healthLabel = 'Terputus';
}

// --- Outbox history ---
let outboxQuery = supabase
  .from('notification_outbox')
  .select('*')
  .order('created_at', { ascending: false })
  .limit(50);
if (statusFilter) outboxQuery = outboxQuery.eq('status', statusFilter);
const { data: outboxRows } = await outboxQuery;

const OUTBOX_STATUS_STYLES: Record<string, string> = {
  pending: 'bg-blue-50 text-blue-700 border border-blue-200',
  sending: 'bg-yellow-50 text-yellow-700 border border-yellow-200',
  sent: 'bg-green-50 text-green-700 border border-green-200',
  failed: 'bg-orange-50 text-orange-700 border border-orange-200',
  dead: 'bg-red-50 text-red-700 border border-red-200',
};

// --- Admin group JID setting ---
const { data: notificationSettings } = await supabase
  .from('notification_settings')
  .select('*')
  .eq('id', 'default')
  .maybeSingle();

const adminGroupJid = notificationSettings?.admin_group_jid || null;

function formatDateTime(iso: string | null) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('id-ID', {
    day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit',
  });
}
---

<AdminLayout title="Notifikasi WhatsApp" activeNav="notifikasi">

  <!-- Bot Health Card -->
  <div class="bg-white border border-border rounded-2xl p-6 mb-6">
    <div class="flex items-center justify-between flex-wrap gap-4">
      <div>
        <h2 class="font-700 text-text-dark text-sm mb-1">Status Bot WhatsApp</h2>
        <p class="text-secondary text-xs">
          {heartbeat?.wa_number ? `Nomor: ${heartbeat.wa_number}` : 'Nomor WhatsApp belum terhubung'}
        </p>
        {heartbeat?.last_heartbeat_at && (
          <p class="text-secondary-light text-xs mt-0.5">
            Heartbeat terakhir: {formatDateTime(heartbeat.last_heartbeat_at)}
          </p>
        )}
      </div>
      <span class={`inline-flex items-center gap-2 text-sm font-700 px-4 py-2 rounded-full ${HEALTH_STYLES[healthTier]}`}>
        <span class={`w-2 h-2 rounded-full flex-shrink-0 ${HEALTH_DOT[healthTier]}`}></span>
        {healthLabel}
      </span>
    </div>
  </div>

  <!-- Outbox History -->
  <div class="bg-white border border-border rounded-2xl overflow-hidden mb-6">
    <div class="px-6 py-5 border-b border-border flex items-center justify-between flex-wrap gap-3">
      <div>
        <h2 class="font-700 text-text-dark text-sm">Riwayat Notifikasi</h2>
        <p class="text-secondary text-xs mt-0.5">50 notifikasi terbaru dari outbox.</p>
      </div>
      <div class="flex items-center gap-2 flex-wrap">
        <a href="/admin/notifikasi" class={`text-xs font-600 px-3 py-1.5 rounded-lg transition-colors ${!statusFilter ? 'bg-primary text-white' : 'bg-bg text-secondary hover:bg-border'}`}>
          Semua
        </a>
        {OUTBOX_STATUSES.map((s) => (
          <a href={`/admin/notifikasi?status=${s}`} class={`text-xs font-600 px-3 py-1.5 rounded-lg transition-colors ${statusFilter === s ? 'bg-primary text-white' : 'bg-bg text-secondary hover:bg-border'}`}>
            {s}
          </a>
        ))}
      </div>
    </div>

    {outboxRows && outboxRows.length > 0 ? (
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border text-left">
              <th class="px-6 py-3 text-secondary text-xs font-600 uppercase tracking-wide">Kode Tiket</th>
              <th class="px-4 py-3 text-secondary text-xs font-600 uppercase tracking-wide">Penerima</th>
              <th class="px-4 py-3 text-secondary text-xs font-600 uppercase tracking-wide">Event</th>
              <th class="px-4 py-3 text-secondary text-xs font-600 uppercase tracking-wide">Status</th>
              <th class="px-4 py-3 text-secondary text-xs font-600 uppercase tracking-wide">Percobaan</th>
              <th class="px-4 py-3 text-secondary text-xs font-600 uppercase tracking-wide">Error Terakhir</th>
              <th class="px-4 py-3 text-secondary text-xs font-600 uppercase tracking-wide">Dibuat</th>
              <th class="px-6 py-3 text-secondary text-xs font-600 uppercase tracking-wide">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            {outboxRows.map((row) => (
              <tr>
                <td class="px-6 py-3 font-600 text-text-dark text-xs font-mono">{row.ticket_code}</td>
                <td class="px-4 py-3 text-secondary text-xs">{row.recipient_role}</td>
                <td class="px-4 py-3 text-secondary text-xs">{row.event_type}</td>
                <td class="px-4 py-3">
                  <span class={`text-xs font-700 px-2.5 py-1 rounded-full ${OUTBOX_STATUS_STYLES[row.status] || 'bg-bg text-secondary border border-border'}`}>
                    {row.status}
                  </span>
                </td>
                <td class="px-4 py-3 text-secondary text-xs">{row.attempt_count} / {row.max_attempts}</td>
                <td class="px-4 py-3 text-secondary text-xs max-w-[220px] truncate" title={row.last_error || ''}>
                  {row.last_error || '—'}
                </td>
                <td class="px-4 py-3 text-secondary text-xs whitespace-nowrap">{formatDateTime(row.created_at)}</td>
                <td class="px-6 py-3">
                  {RETRYABLE_STATUSES.has(row.status) && (
                    <form method="POST">
                      <input type="hidden" name="action" value="retry" />
                      <input type="hidden" name="id" value={row.id} />
                      <button type="submit" class="text-xs font-600 px-3 py-1.5 rounded-lg bg-bg text-secondary hover:bg-border transition-colors whitespace-nowrap">
                        Retry
                      </button>
                    </form>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="py-12 text-center">
        <p class="text-secondary text-sm">Belum ada notifikasi{statusFilter ? ` dengan status "${statusFilter}"` : ''}.</p>
      </div>
    )}
  </div>

  <!-- Grup Admin WhatsApp -->
  <div class="bg-white border border-border rounded-2xl p-6 mb-6">
    <h2 class="font-700 text-text-dark text-sm mb-1">Grup Admin WhatsApp</h2>
    <p class="text-secondary text-xs mb-4">Notifikasi tiket baru untuk admin dikirim ke satu grup WhatsApp ini, bukan ke nomor individual.</p>

    {errorParam === 'invalid_group_jid' && (
      <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-4 flex items-center gap-3 text-red-800 text-sm font-500">
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        JID grup tidak valid. Harus diakhiri dengan "@g.us" (contoh: 120363012345678901@g.us), bukan nomor individual.
      </div>
    )}

    {adminGroupJid ? (
      <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-4 flex items-center gap-3 text-green-800 text-sm font-500">
        <span class="w-2 h-2 rounded-full flex-shrink-0 bg-green-500"></span>
        Grup aktif: <span class="font-mono">{adminGroupJid}</span>
      </div>
    ) : (
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 mb-4 flex items-center gap-3 text-yellow-800 text-sm font-500">
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Belum diatur — notifikasi ke grup admin tidak akan terkirim.
      </div>
    )}

    <form method="POST" class="flex items-center gap-3">
      <input type="hidden" name="action" value="set_admin_group_jid" />
      <input
        id="admin-group-jid"
        name="jid"
        type="text"
        required
        placeholder="Contoh: 120363012345678901@g.us"
        value={adminGroupJid ?? ''}
        class="flex-1 border border-border rounded-xl px-4 py-3 text-sm font-mono focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light placeholder:font-sans"
      />
      <button type="submit" class="bg-primary text-white font-600 text-sm px-5 py-3 rounded-xl hover:bg-primary-hover transition-colors whitespace-nowrap">
        Simpan
      </button>
    </form>
  </div>

</AdminLayout>
