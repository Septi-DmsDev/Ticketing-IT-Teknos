---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabaseAdmin as supabase } from '../../../lib/supabase-admin';
import { canTransitionSupportStatus, isValidSupportStatus } from '../../../lib/status-flow';

const { code } = Astro.params;

const { data: ticket } = await supabase
  .from('support_tickets')
  .select('*')
  .eq('ticket_code', code)
  .maybeSingle();

const { data: itStaffOptions } = await supabase
  .from('profiles')
  .select('id, full_name, role')
  .in('role', ['super_admin', 'it_staff'])
  .order('full_name', { ascending: true });

if (!ticket) return Astro.redirect('/admin/support');

let errorMsg = '';
let successMsg = '';

const URGENCY_LABELS: Record<string, string> = {
  normal: 'Normal',
  urgent: 'Urgent',
  critical: 'Critical',
};
const URGENCY_CLASSES: Record<string, string> = {
  normal: 'bg-slate-100 text-slate-700',
  urgent: 'bg-amber-100 text-amber-800',
  critical: 'bg-red-100 text-red-800',
};

// Handle status update / note update POST
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action') as string;

  if (action === 'update_status') {
    const newStatus = String(form.get('status') || '');

    if (!isValidSupportStatus(ticket.status) || !isValidSupportStatus(newStatus)) {
      errorMsg = 'Status tiket tidak valid.';
    } else if (!canTransitionSupportStatus(ticket.status, newStatus)) {
      errorMsg = 'Perpindahan status support tidak diizinkan.';
    } else {
      const updates: Record<string, unknown> = { status: newStatus };
      if (newStatus === 'resolved') updates.resolved_at = new Date().toISOString();
      const { error } = await supabase.from('support_tickets').update(updates).eq('ticket_code', code);
      if (error) errorMsg = error.message;
      else successMsg = 'Status tiket berhasil diperbarui.';
    }
  }

  if (action === 'update_response') {
    const it_response = form.get('it_response') as string;
    const it_notes = form.get('it_notes') as string;
    const { error } = await supabase.from('support_tickets').update({ it_response, it_notes }).eq('ticket_code', code);
    if (error) errorMsg = error.message;
    else successMsg = 'Respons dan catatan berhasil disimpan.';
  }

  if (action === 'assign_pic') {
    const assignedTo = String(form.get('assigned_to') || '');
    const updates: Record<string, unknown> = { assigned_to: assignedTo || null };

    if (assignedTo && ticket.status === 'open') {
      updates.status = 'assigned';
    }

    const { error } = await supabase.from('support_tickets').update(updates).eq('ticket_code', code);
    if (error) errorMsg = error.message;
    else successMsg = assignedTo ? 'PIC IT berhasil ditetapkan.' : 'Assignment PIC IT berhasil dikosongkan.';
  }

  if (action === 'update_urgency') {
    const urgency = String(form.get('urgency') || 'normal');
    if (!['normal', 'urgent', 'critical'].includes(urgency)) {
      errorMsg = 'Prioritas urgency tidak valid.';
    } else {
      const { error } = await supabase.from('support_tickets').update({ urgency }).eq('ticket_code', code);
      if (error) errorMsg = error.message;
      else successMsg = 'Urgency tiket berhasil diperbarui.';
    }
  }
}

const STATUS_LABELS: Record<string, string> = {
  open: 'Pending', assigned: 'Diterima', in_progress: 'Sedang Dikerjakan',
  resolved: 'Sudah Diperbaiki', closed: 'Selesai (Closed)',
};
const STATUS_FLOW = ['open', 'assigned', 'in_progress', 'resolved'];

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}
---

<AdminLayout title={`Detail Tiket — ${code}`} activeNav="support">
  {successMsg && <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6 text-sm text-green-800">{successMsg}</div>}
  {errorMsg && <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6 text-sm text-red-800">{errorMsg}</div>}

  <div class="flex items-center gap-3 mb-6">
    <a href="/admin/support" class="text-secondary hover:text-text-dark transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    </a>
    <div>
      <h2 class="font-700 text-text-dark">{ticket.category_name || 'Tiket Support'}</h2>
      <p class="text-secondary text-xs font-mono">{ticket.ticket_code}</p>
    </div>
    <div class="ml-auto">
      <span class={`text-sm font-700 px-3 py-1.5 rounded-full badge-${ticket.status}`}>
        {STATUS_LABELS[ticket.status] || ticket.status}
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Left: Details -->
    <div class="lg:col-span-2 space-y-5">

      <!-- Reporter Info -->
      <div class="bg-white border border-border rounded-2xl p-6">
        <h3 class="font-700 text-text-dark text-sm mb-4">Informasi Pelapor</h3>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <p class="text-secondary text-xs mb-1">Nama</p>
            <p class="font-600 text-text-dark text-sm">{ticket.reporter_name}</p>
          </div>
          <div>
            <p class="text-secondary text-xs mb-1">Jabatan</p>
            <p class="font-600 text-text-dark text-sm">{ticket.reporter_position}</p>
          </div>
          <div>
            <p class="text-secondary text-xs mb-1">Divisi</p>
            <p class="font-600 text-text-dark text-sm">{ticket.reporter_division}</p>
          </div>
        </div>
      </div>

      <!-- Ticket Description -->
      <div class="bg-white border border-border rounded-2xl p-6">
        <h3 class="font-700 text-text-dark text-sm mb-3">Deskripsi Masalah</h3>
        <p class="text-secondary text-sm leading-relaxed whitespace-pre-wrap">{ticket.description}</p>
        {ticket.location && (
          <div class="mt-4 pt-4 border-t border-border flex items-center gap-2 text-secondary text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            {ticket.location}
          </div>
        )}
        {ticket.attachment_url && (
          <div class="mt-3">
            <a href={ticket.attachment_url} target="_blank" class="text-primary text-sm font-600 hover:underline flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
              </svg>
              Lihat Lampiran
            </a>
          </div>
        )}
      </div>

      <!-- IT Response Form -->
      <form method="POST" class="bg-white border border-border rounded-2xl p-6">
        <input type="hidden" name="action" value="update_response" />
        <h3 class="font-700 text-text-dark text-sm mb-4">Respons & Catatan</h3>
        <div class="space-y-4">
          <div>
            <label for="it_response" class="block text-sm font-600 text-text-dark mb-2">
              Respons Resmi
              <span class="text-secondary font-400 ml-1">(Terlihat oleh pelapor di halaman tracking)</span>
            </label>
            <textarea id="it_response" name="it_response" rows="3" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all resize-none" placeholder="Tuliskan update atau solusi yang sudah diberikan...">{ticket.it_response || ''}</textarea>
          </div>
          <div>
            <label for="it_notes" class="block text-sm font-600 text-text-dark mb-2">
              Catatan Internal
              <span class="text-secondary font-400 ml-1">(Hanya terlihat oleh tim IT)</span>
            </label>
            <textarea id="it_notes" name="it_notes" rows="2" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all resize-none" placeholder="Catatan teknis, temuan internal, dsb...">{ticket.it_notes || ''}</textarea>
          </div>
          <div class="flex justify-end">
            <button type="submit" class="bg-primary text-white font-600 text-sm px-5 py-2.5 rounded-xl hover:bg-primary-hover transition-colors">
              Simpan
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- Right: Actions -->
    <div class="space-y-5">
      <div class="bg-white border border-border rounded-2xl p-6">
        <h3 class="font-700 text-text-dark text-sm mb-4">Tentukan PIC IT</h3>
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="assign_pic" />
          <div>
            <label for="assigned_to" class="block text-sm font-600 text-text-dark mb-2">PIC Penanganan</label>
            <select id="assigned_to" name="assigned_to" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all bg-white appearance-none">
              <option value="">Belum ditugaskan</option>
              {(itStaffOptions || []).map((staff) => (
                <option value={staff.id} selected={ticket.assigned_to === staff.id}>
                  {staff.full_name} {staff.role === 'super_admin' ? '(Super Admin)' : ''}
                </option>
              ))}
            </select>
          </div>
          <button type="submit" class="w-full bg-primary text-white font-600 text-sm px-5 py-2.5 rounded-xl hover:bg-primary-hover transition-colors">
            Simpan PIC
          </button>
        </form>
      </div>

      <div class="bg-white border border-border rounded-2xl p-6">
        <h3 class="font-700 text-text-dark text-sm mb-4">Atur Urgency</h3>
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="update_urgency" />
          <select name="urgency" class="w-full border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all bg-white appearance-none">
            <option value="normal" selected={ticket.urgency === 'normal'}>Normal</option>
            <option value="urgent" selected={ticket.urgency === 'urgent'}>Urgent</option>
            <option value="critical" selected={ticket.urgency === 'critical'}>Critical</option>
          </select>
          <button type="submit" class="w-full bg-primary text-white font-600 text-sm px-5 py-2.5 rounded-xl hover:bg-primary-hover transition-colors">
            Simpan Urgency
          </button>
        </form>
      </div>

      <!-- Update Status -->
      <div class="bg-white border border-border rounded-2xl p-6">
        <h3 class="font-700 text-text-dark text-sm mb-4">Update Status</h3>
        <form method="POST" class="space-y-3">
          <input type="hidden" name="action" value="update_status" />
          {['open', 'assigned', 'in_progress', 'resolved', 'closed'].filter(s => s !== ticket.status).map(s => (
            <button
              type="submit"
              name="status"
              value={s}
              class={`w-full py-2.5 rounded-xl text-sm font-600 border transition-colors text-left px-4 flex items-center gap-2 ${
                s === 'resolved' || s === 'closed'
                  ? 'border-green-200 bg-green-50 text-green-800 hover:bg-green-100'
                  : 'border-border bg-bg text-text-dark hover:bg-border'
              }`}
            >
              <span class={`w-2 h-2 rounded-full flex-shrink-0 ${
                (s === 'resolved' || s === 'closed') ? 'bg-green-500' : s === 'in_progress' ? 'bg-orange-400' : s === 'assigned' ? 'bg-purple-500' : 'bg-blue-400'
              }`}></span>
              {STATUS_LABELS[s] || s}
            </button>
          ))}
        </form>
      </div>

      <!-- Ticket Info -->
      <div class="bg-white border border-border rounded-2xl p-6">
        <h3 class="font-700 text-text-dark text-sm mb-4">Info Tiket</h3>
        <div class="space-y-3">
          <div class="flex justify-between">
            <p class="text-secondary text-xs">Kategori</p>
            <p class="font-600 text-text-dark text-xs">{ticket.category_name || '—'}</p>
          </div>
          <div class="flex justify-between">
            <p class="text-secondary text-xs">Masuk</p>
            <p class="font-600 text-text-dark text-xs">{formatDate(ticket.created_at)}</p>
          </div>
          <div class="flex justify-between">
            <p class="text-secondary text-xs">PIC IT</p>
            <p class="font-600 text-text-dark text-xs">{itStaffOptions?.find((staff) => staff.id === ticket.assigned_to)?.full_name || 'Belum ditugaskan'}</p>
          </div>
          <div class="flex justify-between items-center">
            <p class="text-secondary text-xs">Urgency</p>
            <span class={`text-[11px] font-700 px-2 py-0.5 rounded-full ${URGENCY_CLASSES[ticket.urgency] || URGENCY_CLASSES.normal}`}>
              {URGENCY_LABELS[ticket.urgency] || ticket.urgency}
            </span>
          </div>
          {ticket.resolved_at && (
            <div class="flex justify-between">
              <p class="text-secondary text-xs">Diselesaikan</p>
              <p class="font-600 text-text-dark text-xs">{formatDate(ticket.resolved_at)}</p>
            </div>
          )}
          <div class="flex justify-between pt-3 border-t border-border">
            <p class="text-secondary text-xs">Usia Tiket</p>
            <p class="font-600 text-text-dark text-xs">
              {((Date.now() - new Date(ticket.created_at).getTime()) / 3600000).toFixed(1)} jam
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</AdminLayout>
