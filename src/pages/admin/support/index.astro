---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabaseAdmin as supabase } from '../../../lib/supabase-admin';

const statusFilter = Astro.url.searchParams.get('status') || 'all';
const assigneeFilter = Astro.url.searchParams.get('assignee') || 'all';
const searchFilter = (Astro.url.searchParams.get('q') || '').trim();

function redirectTarget(status: string, assignee: string, search: string) {
  const params = new URLSearchParams();
  if (status && status !== 'all') params.set('status', status);
  if (assignee && assignee !== 'all') params.set('assignee', assignee);
  if (search) params.set('q', search);
  const query = params.toString();
  return `/admin/support${query ? `?${query}` : ''}`;
}

let successMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('action') || '');

  if (action === 'quick_assign') {
    const ticketCode = String(form.get('ticket_code') || '');
    const assignedTo = String(form.get('assigned_to') || '');

    const { data: currentTicket } = await supabase
      .from('support_tickets')
      .select('status')
      .eq('ticket_code', ticketCode)
      .maybeSingle();

    const updates: Record<string, unknown> = { assigned_to: assignedTo || null };
    if (assignedTo && currentTicket?.status === 'open') {
      updates.status = 'assigned';
    }

    const { error } = await supabase.from('support_tickets').update(updates).eq('ticket_code', ticketCode);
    if (error) errorMsg = error.message;
    else successMsg = assignedTo ? `PIC tiket ${ticketCode} berhasil diperbarui.` : `PIC tiket ${ticketCode} berhasil dikosongkan.`;
  }
}

const { data: itStaffOptions } = await supabase
  .from('profiles')
  .select('id, full_name, role')
  .in('role', ['super_admin', 'it_staff'])
  .order('full_name', { ascending: true });

let query = supabase
  .from('support_tickets')
  .select('*, assigned_profile:profiles!support_tickets_assigned_to_fkey(full_name)')
  .order('created_at', { ascending: true });

if (statusFilter !== 'all') {
  query = query.eq('status', statusFilter);
}

if (assigneeFilter === 'unassigned') {
  query = query.is('assigned_to', null);
} else if (assigneeFilter !== 'all') {
  query = query.eq('assigned_to', assigneeFilter);
}

if (searchFilter) {
  const escaped = searchFilter.replace(/[%_,]/g, '');
  query = query.or([
    `ticket_code.ilike.%${escaped}%`,
    `reporter_name.ilike.%${escaped}%`,
    `reporter_division.ilike.%${escaped}%`,
    `category_name.ilike.%${escaped}%`,
  ].join(','));
}

const { data: tickets } = await query;

const STATUS_LABELS: Record<string, string> = {
  open: 'Pending', assigned: 'Diterima', in_progress: 'Sedang Dikerjakan',
  resolved: 'Sudah Diperbaiki', closed: 'Selesai (Closed)',
};
const URGENCY_LABELS: Record<string, string> = { normal: 'Normal', urgent: 'Urgent', critical: 'Critical' };
const URGENCY_CLASSES: Record<string, string> = {
  normal: 'bg-slate-100 text-slate-700',
  urgent: 'bg-amber-100 text-amber-800',
  critical: 'bg-red-100 text-red-800',
};
const STATUS_CLASSES: Record<string, string> = {
  open: 'badge-open', assigned: 'badge-assigned', in_progress: 'badge-in-progress',
  resolved: 'badge-resolved', closed: 'badge-closed',
};

function getSLAHours(createdAt: string) {
  return ((Date.now() - new Date(createdAt).getTime()) / 3600000).toFixed(1);
}

function isSLABreached(createdAt: string, status: string) {
  if (['resolved', 'closed'].includes(status)) return false;
  return (Date.now() - new Date(createdAt).getTime()) > 2 * 3600000;
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
}
---

<AdminLayout title="Tiket Support" activeNav="support">
  {successMsg && <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6 text-sm text-green-800">{successMsg}</div>}
  {errorMsg && <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6 text-sm text-red-800">{errorMsg}</div>}

  <!-- Filter Tabs -->
  <div class="flex items-center gap-2 mb-6 flex-wrap">
    {['all', 'open', 'assigned', 'in_progress', 'resolved', 'closed'].map(s => (
      <a
        href={redirectTarget(s, assigneeFilter, searchFilter)}
        class={`px-4 py-2 rounded-xl text-sm font-500 transition-colors ${
          statusFilter === s
            ? 'bg-primary text-white'
            : 'bg-white border border-border text-secondary hover:text-text-dark hover:border-secondary'
        }`}
      >
        {s === 'all' ? 'Semua' : STATUS_LABELS[s] || s}
      </a>
    ))}
  </div>

  <div class="bg-white border border-border rounded-2xl p-4 mb-6 flex flex-col lg:flex-row lg:items-center gap-3">
    <div class="min-w-0 flex-1">
      <p class="text-sm font-600 text-text-dark">Filter PIC IT</p>
      <p class="text-xs text-secondary mt-1">Saring tiket berdasarkan penanggung jawab saat ini.</p>
    </div>
    <form method="GET" class="flex flex-col sm:flex-row sm:items-center gap-3 flex-wrap w-full lg:w-auto">
      {statusFilter !== 'all' && <input type="hidden" name="status" value={statusFilter} />}
      <select name="assignee" class="border border-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all bg-white appearance-none">
        <option value="all" selected={assigneeFilter === 'all'}>Semua PIC</option>
        <option value="unassigned" selected={assigneeFilter === 'unassigned'}>Belum ditugaskan</option>
        {(itStaffOptions || []).map((staff) => (
          <option value={staff.id} selected={assigneeFilter === staff.id}>{staff.full_name}</option>
        ))}
      </select>
      <button type="submit" class="bg-primary text-white font-600 text-sm px-4 py-2.5 rounded-xl hover:bg-primary-hover transition-colors">Terapkan</button>
      <a href={redirectTarget(statusFilter, 'all', searchFilter)} class="text-secondary text-sm hover:text-text-dark transition-colors">Reset PIC</a>
    </form>
  </div>

  <div class="bg-white border border-border rounded-2xl p-4 mb-6 flex flex-col lg:flex-row lg:items-center gap-3">
    <div class="min-w-0 flex-1">
      <p class="text-sm font-600 text-text-dark">Pencarian Cepat</p>
      <p class="text-xs text-secondary mt-1">Cari berdasarkan kode tiket, nama pelapor, divisi, atau kategori.</p>
    </div>
    <form method="GET" class="flex items-center gap-3 flex-wrap">
      {statusFilter !== 'all' && <input type="hidden" name="status" value={statusFilter} />}
      {assigneeFilter !== 'all' && <input type="hidden" name="assignee" value={assigneeFilter} />}
      <input
        type="text"
        name="q"
        value={searchFilter}
        placeholder="Contoh: SUP-2026, Operasional, Printer"
        class="w-full sm:min-w-[280px] border border-border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-secondary-light"
      />
      <button type="submit" class="bg-primary text-white font-600 text-sm px-4 py-2.5 rounded-xl hover:bg-primary-hover transition-colors">Cari</button>
      <a href={redirectTarget(statusFilter, assigneeFilter, '')} class="text-secondary text-sm hover:text-text-dark transition-colors">Reset Cari</a>
      <a href="/admin/support" class="text-secondary text-sm hover:text-text-dark transition-colors">Reset Semua</a>
    </form>
  </div>

  <!-- Tickets Table -->
  <div class="bg-white border border-border rounded-2xl overflow-hidden">
    {tickets && tickets.length > 0 ? (
      <div class="overflow-x-auto">
        <table class="w-full min-w-[980px] text-sm">
          <thead>
            <tr class="border-b border-border bg-bg">
              <th class="text-left px-6 py-4 font-600 text-secondary text-xs uppercase tracking-wide">Kode Tiket</th>
              <th class="text-left px-6 py-4 font-600 text-secondary text-xs uppercase tracking-wide">Pelapor</th>
              <th class="text-left px-6 py-4 font-600 text-secondary text-xs uppercase tracking-wide">Kategori</th>
              <th class="text-left px-6 py-4 font-600 text-secondary text-xs uppercase tracking-wide">Urgency</th>
              <th class="text-left px-6 py-4 font-600 text-secondary text-xs uppercase tracking-wide">PIC IT</th>
              <th class="text-left px-6 py-4 font-600 text-secondary text-xs uppercase tracking-wide">Quick Assign</th>
              <th class="text-left px-6 py-4 font-600 text-secondary text-xs uppercase tracking-wide">Status</th>
              <th class="text-left px-6 py-4 font-600 text-secondary text-xs uppercase tracking-wide">SLA</th>
              <th class="text-left px-6 py-4 font-600 text-secondary text-xs uppercase tracking-wide">Masuk</th>
              <th class="text-left px-6 py-4 font-600 text-secondary text-xs uppercase tracking-wide"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            {tickets.map((t) => (
              <tr class="hover:bg-bg transition-colors">
                <td class="px-6 py-4">
                  <span class="font-mono text-primary text-xs font-700">{t.ticket_code}</span>
                </td>
                <td class="px-6 py-4">
                  <p class="font-600 text-text-dark">{t.reporter_name}</p>
                  <p class="text-secondary text-xs">{t.reporter_division}</p>
                </td>
                <td class="px-6 py-4 text-secondary">{t.category_name || '—'}</td>
                <td class="px-6 py-4">
                  <span class={`text-xs font-700 px-2 py-0.5 rounded-full ${URGENCY_CLASSES[t.urgency] || URGENCY_CLASSES.normal}`}>
                    {URGENCY_LABELS[t.urgency] || t.urgency}
                  </span>
                </td>
                <td class="px-6 py-4 text-secondary">{t.assigned_profile?.full_name || '—'}</td>
                <td class="px-6 py-4 min-w-[220px]">
                  <form method="POST" class="flex items-center gap-2 min-w-[220px]">
                    <input type="hidden" name="action" value="quick_assign" />
                    <input type="hidden" name="ticket_code" value={t.ticket_code} />
                    <input type="hidden" name="status_context" value={statusFilter} />
                    <select name="assigned_to" class="flex-1 border border-border rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all bg-white appearance-none">
                      <option value="">Belum ditugaskan</option>
                      {(itStaffOptions || []).map((staff) => (
                        <option value={staff.id} selected={t.assigned_to === staff.id}>{staff.full_name}</option>
                      ))}
                    </select>
                    <button type="submit" class="text-xs font-600 px-3 py-2 rounded-lg bg-bg text-secondary hover:bg-border transition-colors whitespace-nowrap">
                      Simpan
                    </button>
                  </form>
                </td>
                <td class="px-6 py-4">
                  <span class={`text-xs font-600 px-2.5 py-1 rounded-full ${STATUS_CLASSES[t.status] || ''}`}>
                    {STATUS_LABELS[t.status] || t.status}
                  </span>
                </td>
                <td class="px-6 py-4">
                  {!['resolved', 'closed'].includes(t.status) && (
                    <span class={`text-xs font-600 px-2 py-0.5 rounded-full ${
                      isSLABreached(t.created_at, t.status)
                        ? 'bg-red-50 text-red-700'
                        : 'bg-green-50 text-green-700'
                    }`}>
                      {getSLAHours(t.created_at)}j {isSLABreached(t.created_at, t.status) ? '⚠' : '✓'}
                    </span>
                  )}
                  {['resolved', 'closed'].includes(t.status) && (
                    <span class="text-secondary-light text-xs">—</span>
                  )}
                </td>
                <td class="px-6 py-4 text-secondary text-xs">{formatDate(t.created_at)}</td>
                <td class="px-6 py-4">
                  <a href={`/admin/support/${t.ticket_code}`} class="text-primary text-xs font-600 hover:underline whitespace-nowrap">
                    Detail →
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="py-16 text-center">
        <div class="w-14 h-14 bg-bg rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-secondary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <p class="font-600 text-text-dark mb-1">Tidak ada tiket</p>
        <p class="text-secondary text-sm">Belum ada tiket support dengan filter ini.</p>
      </div>
    )}
  </div>

</AdminLayout>
