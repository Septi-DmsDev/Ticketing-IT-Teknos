---
import Layout from '../layouts/Layout.astro';
import OnboardingPopup from '../components/OnboardingPopup.astro';
---

<Layout title="Beranda">
  <OnboardingPopup />

  <main class="min-h-screen bg-bg flex flex-col">

    <!-- Header -->
    <header class="bg-primary">
      <div class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-white/15 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div>
            <p class="text-white font-600 text-sm leading-tight">IT Ticketing System</p>
            <p class="text-white/50 text-xs">Departemen Teknologi Informasi</p>
          </div>
        </div>
        <a href="/admin/login" class="text-white/60 hover:text-white text-xs font-500 transition-colors flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          Login IT
        </a>
      </div>
    </header>

    <!-- Hero Section -->
    <section class="max-w-5xl mx-auto px-6 pt-16 pb-12 text-center">
      <div class="inline-flex items-center gap-2 bg-white border border-border rounded-full px-4 py-1.5 text-xs text-secondary font-500 mb-6 shadow-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block"></span>
        Sistem aktif & siap menerima laporan
      </div>
      <h1 class="text-4xl font-700 text-primary leading-tight mb-4">
        Butuh bantuan IT atau<br/>punya ide untuk sistem baru?
      </h1>
      <p class="text-secondary text-lg max-w-xl mx-auto mb-10">
        Laporkan kendala teknis atau ajukan permintaan pengembangan melalui sistem terpusat kami. Tidak perlu akun, langsung bisa digunakan.
      </p>

      <!-- CTA Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-2xl mx-auto mb-12">
        
        <!-- Card Pengajuan Sistem Baru -->
        <a id="btn-pengajuan" href="/pengajuan" class="group bg-white border border-border rounded-2xl p-7 text-left hover:border-primary hover:shadow-lg transition-all duration-200 hover:-translate-y-1">
          <div class="w-12 h-12 bg-primary/8 rounded-xl flex items-center justify-center mb-5 group-hover:bg-primary/12 transition-colors">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
          </div>
          <h2 class="font-700 text-text-dark text-lg mb-2">Ajukan Sistem Baru</h2>
          <p class="text-secondary text-sm leading-relaxed mb-5">Punya ide fitur atau butuh sistem/aplikasi baru? Sampaikan kebutuhan Anda ke tim IT untuk dianalisis.</p>
          <span class="inline-flex items-center gap-1.5 text-primary font-600 text-sm group-hover:gap-2.5 transition-all">
            Buat Pengajuan
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <!-- Card Lapor Kendala -->
        <a id="btn-support" href="/support" class="group bg-white border border-border rounded-2xl p-7 text-left hover:border-primary hover:shadow-lg transition-all duration-200 hover:-translate-y-1">
          <div class="w-12 h-12 bg-primary/8 rounded-xl flex items-center justify-center mb-5 group-hover:bg-primary/12 transition-colors">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </div>
          <h2 class="font-700 text-text-dark text-lg mb-2">Lapor Kendala (Support)</h2>
          <p class="text-secondary text-sm leading-relaxed mb-5">Ada jaringan mati, hardware rusak, atau error sistem? Laporkan sekarang dan tim IT akan segera menangani.</p>
          <span class="inline-flex items-center gap-1.5 text-primary font-600 text-sm group-hover:gap-2.5 transition-all">
            Buat Laporan
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

      </div>

      <!-- Cek Status Tiket -->
      <div class="bg-white border border-border rounded-2xl p-7 max-w-2xl mx-auto">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 bg-primary/8 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <div class="text-left">
            <h3 class="font-600 text-text-dark text-sm">Cek Status Tiket</h3>
            <p class="text-secondary text-xs">Masukkan kode tiket yang Anda terima saat submit</p>
          </div>
        </div>
        <div class="flex gap-3">
          <input
            id="ticket-code-input"
            type="text"
            placeholder="Contoh: SUP-2026-A7B2 atau REQ-2026-X9C1"
            class="flex-1 border border-border rounded-xl px-4 py-3 text-sm text-text-dark placeholder:text-secondary-light focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all font-mono"
            onkeydown="if(event.key==='Enter') trackTicket()"
          />
          <button
            id="btn-track"
            onclick="trackTicket()"
            class="bg-primary text-white font-600 text-sm px-5 py-3 rounded-xl hover:bg-primary-hover transition-colors whitespace-nowrap"
          >
            Lacak
          </button>
        </div>
      </div>
    </section>

    <!-- Info strip -->
    <section class="max-w-5xl mx-auto px-6 pb-16 w-full">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="flex items-center gap-3 bg-white border border-border rounded-xl px-5 py-4">
          <svg class="w-5 h-5 text-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          <p class="text-sm text-secondary">Tanpa akun, langsung bisa lapor</p>
        </div>
        <div class="flex items-center gap-3 bg-white border border-border rounded-xl px-5 py-4">
          <svg class="w-5 h-5 text-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-sm text-secondary">SLA respons support: <strong class="text-text-dark">2 jam</strong></p>
        </div>
        <div class="flex items-center gap-3 bg-white border border-border rounded-xl px-5 py-4">
          <svg class="w-5 h-5 text-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <p class="text-sm text-secondary">Notifikasi progress via WhatsApp</p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="mt-auto border-t border-border">
      <div class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
        <p class="text-secondary-light text-xs">© {new Date().getFullYear()} Departemen IT. All rights reserved.</p>
        <button 
          onclick="localStorage.removeItem('it_ticketing_onboarding_seen'); location.reload();"
          class="text-secondary-light hover:text-secondary text-xs transition-colors"
        >
          Buka Panduan
        </button>
      </div>
    </footer>

  </main>
</Layout>

<script>
  function trackTicket() {
    const input = document.getElementById('ticket-code-input') as HTMLInputElement;
    const code = input?.value.trim().toUpperCase();
    if (!code) {
      input?.focus();
      return;
    }
    window.location.href = `/tracking?code=${encodeURIComponent(code)}`;
  }
  (window as any).trackTicket = trackTicket;
</script>
