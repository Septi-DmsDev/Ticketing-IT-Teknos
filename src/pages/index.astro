---
import Layout from '../layouts/Layout.astro';
import OnboardingPopup from '../components/OnboardingPopup.astro';
---

<Layout title="Beranda">
  <OnboardingPopup />

  <main class="min-h-screen bg-bg flex flex-col">

    <!-- Header -->
    <header class="bg-primary/95 backdrop-blur-md border-b border-white/10 sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3 group cursor-pointer">
          <div class="w-9 h-9 bg-gradient-to-br from-white/20 to-white/5 rounded-xl flex items-center justify-center shadow-inner border border-white/10 group-hover:scale-105 transition-transform">
            <svg class="w-5 h-5 text-white drop-shadow-md" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div>
            <p class="text-white font-600 text-sm leading-tight tracking-wide">IT Ticketing System</p>
            <p class="text-white/60 text-[11px] font-500 uppercase tracking-widest mt-0.5">Departemen Teknologi Informasi</p>
          </div>
        </div>
        <a href="/admin/login" class="bg-white/10 hover:bg-white/20 border border-white/10 text-white text-xs font-600 px-4 py-2 rounded-lg transition-all hover:shadow-[0_0_15px_rgba(255,255,255,0.2)] flex items-center gap-2">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
          </svg>
          Login IT
        </a>
      </div>
    </header>

    <!-- Hero Section -->
    <section class="max-w-5xl mx-auto px-6 pt-20 pb-16 text-center relative z-10">
      <div class="inline-flex items-center gap-2 bg-white/80 backdrop-blur-sm border border-primary/10 rounded-full px-4 py-1.5 text-xs text-primary font-600 mb-8 shadow-sm hover:shadow-md transition-shadow cursor-default">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        Sistem aktif & siap menerima laporan
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-800 text-transparent bg-clip-text bg-gradient-to-r from-primary via-[#002888] to-primary leading-[1.1] mb-6 tracking-tight">
        Butuh bantuan IT atau<br/>punya ide untuk sistem baru?
      </h1>
      <p class="text-secondary-light text-lg max-w-2xl mx-auto mb-12 font-500 leading-relaxed">
        Laporkan kendala teknis atau ajukan permintaan pengembangan melalui sistem terpusat kami. Cepat, transparan, dan tanpa perlu membuat akun.
      </p>

      <!-- Main Action Cards (Bento Style) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto text-left">
        
        <a href="/pengajuan" class="group glass-card rounded-3xl p-8 hover-lift relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-3xl group-hover:bg-primary/10 transition-colors"></div>
          <div class="w-14 h-14 bg-gradient-to-br from-primary to-primary-hover rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-primary/30 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h2 class="text-2xl font-700 text-primary mb-3 group-hover:text-primary-hover transition-colors">Ajukan Sistem Baru</h2>
          <p class="text-secondary text-sm leading-relaxed mb-6">Punya ide aplikasi atau fitur baru untuk mempermudah pekerjaan divisi Anda? Ajukan proposalnya di sini.</p>
          <div class="inline-flex items-center gap-2 text-primary font-600 text-sm group-hover:gap-3 transition-all">
            Buat Pengajuan
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </div>
        </a>

        <a href="/support" class="group glass-card rounded-3xl p-8 hover-lift relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-amber-500/5 rounded-full blur-3xl group-hover:bg-amber-500/10 transition-colors"></div>
          <div class="w-14 h-14 bg-gradient-to-br from-amber-500 to-orange-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-amber-500/30 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h2 class="text-2xl font-700 text-text-dark mb-3 group-hover:text-amber-600 transition-colors">Lapor Kendala (Support)</h2>
          <p class="text-secondary text-sm leading-relaxed mb-6">Mengalami masalah dengan PC, printer, jaringan, atau error pada aplikasi? Tim IT siap membantu Anda.</p>
          <div class="inline-flex items-center gap-2 text-amber-600 font-600 text-sm group-hover:gap-3 transition-all">
            Lapor Masalah
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </div>
        </a>

      </div>

      <!-- Cek Status Tiket -->
      <div class="bg-white border border-border rounded-2xl p-7 max-w-2xl mx-auto">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 bg-primary/8 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <div class="text-left">
            <h3 class="font-600 text-text-dark text-sm">Cek Status Tiket</h3>
            <p class="text-secondary text-xs">Masukkan kode tiket yang Anda terima saat submit</p>
          </div>
        </div>
        <div class="flex gap-3">
          <input
            id="ticket-code-input"
            type="text"
            placeholder="Contoh: SUP-2026-A7B2 atau REQ-2026-X9C1"
            class="flex-1 border border-border rounded-xl px-4 py-3 text-sm text-text-dark placeholder:text-secondary-light focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all font-mono"
            onkeydown="if(event.key==='Enter') trackTicket()"
          />
          <button
            id="btn-track"
            onclick="trackTicket()"
            class="bg-primary text-white font-600 text-sm px-5 py-3 rounded-xl hover:bg-primary-hover transition-colors whitespace-nowrap"
          >
            Lacak
          </button>
        </div>
      </div>
    </section>


    <!-- Footer -->
    <footer class="mt-auto border-t border-border">
      <div class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
        <p class="text-secondary-light text-xs">© {new Date().getFullYear()} Departemen IT. All rights reserved.</p>
        <button 
          onclick="localStorage.removeItem('it_ticketing_onboarding_seen'); location.reload();"
          class="text-secondary-light hover:text-secondary text-xs transition-colors"
        >
          Buka Panduan
        </button>
      </div>
    </footer>

  </main>
</Layout>

<script>
  function trackTicket() {
    const input = document.getElementById('ticket-code-input') as HTMLInputElement;
    const code = input?.value.trim().toUpperCase();
    if (!code) {
      input?.focus();
      return;
    }
    window.location.href = `/tracking?code=${encodeURIComponent(code)}`;
  }
  (window as any).trackTicket = trackTicket;
</script>
